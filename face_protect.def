Bootstrap: docker
From: nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04

%labels
    Maintainer "iwaokimura"
    Version    "1.0"
    CUDA       "12.4"
    Source     "https://github.com/iwaokimura/face_protect"

%help
    顔写真への不可視敵対的摂動付与ツール（顔認識回避）
    対象: コンパクトデジカメ撮影 JPEG (12MP 前後)
    GPU:  RTX 4090 (CUDA 12.4)

    ─── GHCR から取得（推奨・root 不要） ────────────────
    singularity pull face_protect.sif \
        docker://ghcr.io/iwaokimura/face_protect:latest

    ─── Sylabs Remote Build ─────────────────────────────
    singularity build --remote face_protect.sif face_protect.def

    ─── 初回: モデルダウンロード ─────────────────────────
    singularity exec --nv \
        --bind ./models:/models \
        face_protect.sif \
        python3 /opt/face_protect.py --download-models --models /models

    ─── 1枚処理 ──────────────────────────────────────────
    singularity run --nv \
        --bind ./models:/models \
        --bind ./photos:/data/input:ro \
        --bind ./output:/data/output \
        face_protect.sif \
        --input /data/input/photo.jpg \
        --output /data/output --models /models

%post
    export DEBIAN_FRONTEND=noninteractive

    apt-get update -qq
    apt-get install -y --no-install-recommends \
        python3 python3-pip python3-dev \
        libgl1-mesa-glx libglib2.0-0 \
        libsm6 libxext6 libxrender-dev \
        libgomp1 libjpeg-turbo8 libpng16-16 \
        wget curl ca-certificates git
    rm -rf /var/lib/apt/lists/*

    python3 -m pip install --no-cache-dir --upgrade pip setuptools wheel

    # PyTorch CUDA 12.4
    python3 -m pip install --no-cache-dir \
        torch==2.5.1 torchvision==0.20.1 torchaudio==2.5.1 \
        --index-url https://download.pytorch.org/whl/cu124

    # 顔検出・認識
    python3 -m pip install --no-cache-dir \
        "insightface==0.7.3" \
        "onnxruntime-gpu==1.20.1" \
        "facenet-pytorch==2.6.0"

    # 画像処理・ユーティリティ
    python3 -m pip install --no-cache-dir \
        opencv-python-headless \
        Pillow numpy scipy lpips tqdm rich

    # ArcFace PyTorch バックボーン
    git clone --depth=1 --filter=blob:none --sparse \
        https://github.com/deepinsight/insightface.git /tmp/insightface_src
    cd /tmp/insightface_src
    git sparse-checkout set recognition/arcface_torch
    cp -r recognition/arcface_torch /opt/arcface_torch
    cd / && rm -rf /tmp/insightface_src

    python3 -m pip cache purge

%environment
    export CUDA_HOME=/usr/local/cuda
    export PATH="$PATH:/usr/local/cuda/bin"
    export LD_LIBRARY_PATH="$LD_LIBRARY_PATH:/usr/local/cuda/lib64"
    export PYTHONPATH="/opt/arcface_torch:${PYTHONPATH:-}"
    export PYTHONUNBUFFERED=1
    export OMP_NUM_THREADS=4
    export GLOG_minloglevel=2
    export TF_CPP_MIN_LOG_LEVEL=3

%files
    face_protect.py /opt/face_protect.py

%runscript
    exec python3 /opt/face_protect.py "$@"

%test
    python3 -c "
import torch, insightface
from facenet_pytorch import InceptionResnetV1
import cv2
print(f'PyTorch {torch.__version__} | CUDA={torch.cuda.is_available()}')
if torch.cuda.is_available():
    print(f'GPU: {torch.cuda.get_device_name(0)}')
print(f'InsightFace {insightface.__version__} | OpenCV {cv2.__version__}')
print('ALL OK')
"
